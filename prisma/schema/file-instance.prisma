model FileInstance {
  id String @id @default(uuid())

  filename         String
  originalFilename String
  path             String
  url              String
  fileType         FileType @default(any)
  mimeType         String
  size             Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // privateMessages PrivateMessage[]
  privateMessages PrivateMessage[]

  @@map("file_instance")
}

enum FileType {
  image
  docs
  link
  document
  any
  video
  audio
}
